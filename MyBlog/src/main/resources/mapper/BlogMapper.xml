<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.tsz.myblog.mapper.BlogMapper">
    <!--将查询到的一行行博客数据映射到BlogEntity中-->
    <resultMap id="BlogResultMap" type="com.tsz.myblog.pojo.entity.BlogEntity">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="author" column="author"/>
        <result property="wordCount" column="word_count"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="InsertBlog">
        INSERT INTO blog(id, title, content, author, word_count, create_time)
        VALUES (#{id}, #{title}, #{content}, #{author}, #{wordCount}, #{createTime});
    </insert>
    <!-- 错误写法<select id="getBlogList" resultType="com.tsz.myblog.pojo.vo.GetBlogListVO">-->
    <select id="getBlogList" resultMap="BlogResultMap">
        SELECT * FROM blog;
    </select>
    <select id="getBlogData" resultType="java.util.HashMap">
        SELECT
            COUNT(*) AS totalBlogs,
            SUM(word_count) AS totalWords,
            AVG(word_count) AS avgWordsPerBlog,
            MAX(create_time) AS lastUpdated
        FROM blog;
    </select>
    <!--DATE_SUB(NOW(), INTERVAL 7 DAY)：计算当前时间往前推 7 天的时间点
        WHERE create_time >= ...：筛选创建时间大于等于 7 天前的博客（即一周内的博客）
        ORDER BY create_time DESC：按创建时间降序排列，最新的博客排在前面-->
    <select id="getRecentBlogList" resultMap="BlogResultMap">
        SELECT * FROM blog
        WHERE create_time >= DATE_SUB(NOW(), INTERVAL 7 DAY)
        ORDER BY create_time DESC;
    </select>
</mapper>